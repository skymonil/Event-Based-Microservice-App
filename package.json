{
	"name": "Event-Based-Microservice-App",
	"private": true,
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"test": "pnpm -r run test",
		"test:watch": "pnpm -r run test:watch",
		"test:user": "pnpm --filter user-service run test:watch",
		"test:inventory": "pnpm --filter inventory-service run test:watch",
		"test:order": "pnpm --filter order-service run test:watch",
		"test:payment": "pnpm --filter payment-service run test:watch",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"check:all": "biome check --write --unsafe .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.30.0",
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"esbuild": "^0.27.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,json,css}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
